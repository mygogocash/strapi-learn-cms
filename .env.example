# Copy to .env for local dev. Never commit .env.

HOST=0.0.0.0
PORT=1337

# Comma-separated keys (generate: openssl rand -base64 32) — reuse in production
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# --- Local SQLite (default) ---
DATABASE_CLIENT=sqlite

# --- PostgreSQL (GCP Cloud SQL + Cloud Run) ---
# DATABASE_CLIENT=postgres
# CLOUDSQL_CONNECTION_NAME=gogocash-cms:asia-southeast1:YOUR_INSTANCE
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=
# Or use a connection string (TCP / local) instead of socket + vars above:
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/strapi

# Optional: trust proxy / public URL for admin (behind HTTPS terminator)
# PUBLIC_URL=https://your-service-xxxxx.run.app
